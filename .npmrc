# tree-sitter grammar packages declare conflicting peer deps on the tree-sitter
# Node binding (some want ^0.21.0, others ^0.25.0). We pin tree-sitter@0.25.x
# and the grammars work fine at runtime; the peer ranges are unsatisfiable
# simultaneously, so we relax peer-dep enforcement instead of version-pinning.
legacy-peer-deps=true
build-from-source=true
CXXFLAGS=-std=c++20
